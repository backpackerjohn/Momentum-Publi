rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidAppData(data) {
      return data.keys().hasAll(['data']) && data.keys().size() == 1
             && (data.data is map || data.data is list || data.data == null || data.data is string || data.data is bool || data.data is number);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) && data.keys().size() == 2
             && data.email is string && data.email.size() <= 256
             && data.createdAt is timestamp;
    }

    // --- Collections ---

    // Root User Document
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
                    && incoming().email == existing().email  // Email is immutable for now
                    && incoming().createdAt == existing().createdAt; // Creation date is immutable
    }

    // App Data Collection
    match /users/{userId}/appData/{docId} {
      allow list, get: if isOwner(userId) && isValidId(docId);
      allow create: if isOwner(userId) && isValidId(docId) && isValidAppData(incoming());
      allow update: if isOwner(userId) && isValidId(docId) && isValidAppData(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['data']);
      allow delete: if isOwner(userId) && isValidId(docId);
    }

    // Test connection check
    match /test/connection {
      allow read: if isSignedIn();
    }
  }
}
